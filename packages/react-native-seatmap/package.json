{
  "name": "@seatmaps.com/react-native-seatmap",
  "version": "0.1.0",
  "description": "React Native port of the Jets SeatMap library",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "build": "bob build"
  },
  "keywords": [
    "react-native",
    "seatmap",
    "airline",
    "seats",
    "jets"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-svg": ">=13.0.0"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.31.0",
    "typescript": "^5.9.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": ["commonjs", "module", "typescript"]
  }
}
