{
  "name": "@seatmaps.com/react-native-seatmap",
  "version": "0.1.0",
  "description": "React Native port of the Jets SeatMap library",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "build": "bob build",
    "format": "prettier --write src/"
  },
  "keywords": [
    "react-native",
    "seatmap",
    "airline",
    "seats",
    "jets"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-svg": ">=13.0.0"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "~19.2.14",
    "jest": "^30.3.0",
    "prettier": "^3.3.0",
    "react": "19.2.4",
    "react-native": "0.84.1",
    "react-test-renderer": "19.2.4",
    "react-native-builder-bob": "^0.40.18",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
    "testMatch": ["**/__tests__/**/*.{ts,tsx}", "**/*.test.{ts,tsx}"],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-svg|@seatmaps.com)/)"
    ],
    "modulePaths": ["<rootDir>/node_modules", "<rootDir>/../../node_modules"]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": ["commonjs", "module", "typescript"]
  }
}
